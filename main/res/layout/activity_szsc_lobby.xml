<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SZSC_lobby">

    <TextView
        android:id="@+id/SZSC_lobby_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/SZSC_create_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="创建房间"
        app:layout_constraintEnd_toStartOf="@id/SZSC_lobby_middle"
        app:layout_constraintTop_toTopOf="@id/SZSC_lobby_middle"
        app:layout_constraintBottom_toBottomOf="@id/SZSC_lobby_middle"
        android:layout_marginEnd="16dp"/>

    <Button
        android:id="@+id/SZSC_join_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="加入房间"
        app:layout_constraintStart_toEndOf="@id/SZSC_lobby_middle"
        app:layout_constraintTop_toTopOf="@id/SZSC_lobby_middle"
        app:layout_constraintBottom_toBottomOf="@id/SZSC_lobby_middle"
        android:layout_marginStart="16dp"/>

    <Button
        android:id="@+id/SZSC_open_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="开箱"
        app:layout_constraintTop_toBottomOf="@id/SZSC_create_room"
        app:layout_constraintStart_toStartOf="@id/SZSC_create_room"
        app:layout_constraintEnd_toEndOf="@id/SZSC_create_room"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/SZSC_manage_assets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="管理资产"
        app:layout_constraintTop_toBottomOf="@id/SZSC_join_room"
        app:layout_constraintStart_toStartOf="@id/SZSC_join_room"
        app:layout_constraintEnd_toEndOf="@id/SZSC_join_room"
        android:layout_marginTop="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>