<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SZSC_game_choose_character">

    <TextView
        android:id="@+id/SZSC_game_choose_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/SZSC_game_choose_default_character_list_Scrollview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E9D526"
        app:layout_constraintBottom_toTopOf="@id/SZSC_game_choose_middle"
        app:layout_constraintRight_toLeftOf="@id/SZSC_game_choose_middle"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TableLayout
                android:id="@+id/SZSC_game_choose_default_character_interface_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#188BE6"
                android:orientation="vertical"/>
        </HorizontalScrollView>
    </ScrollView>
    <ScrollView
        android:id="@+id/SZSC_game_choose_character_list_Scrollview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E9D526"
        app:layout_constraintBottom_toTopOf="@id/SZSC_game_choose_middle"
        app:layout_constraintLeft_toRightOf="@id/SZSC_game_choose_middle"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TableLayout
                android:id="@+id/SZSC_game_choose_character_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#188BE6"
                android:orientation="vertical"
                />

        </HorizontalScrollView>
    </ScrollView>





    <Button
        android:id="@+id/SZSC_user_choose_character_this_one"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="确认"
        android:maxLength="8"
        app:layout_constraintTop_toBottomOf="@id/SZSC_game_choose_middle"
        app:layout_constraintRight_toLeftOf="@id/SZSC_game_choose_middle"/>
    <Button
        android:id="@+id/SZSC_user_choose_character_surrender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="投降"
        app:layout_constraintTop_toBottomOf="@id/SZSC_game_choose_middle"
        app:layout_constraintLeft_toRightOf="@id/SZSC_game_choose_middle"/>

</androidx.constraintlayout.widget.ConstraintLayout>